# ===================================================================
# VARIABLES DE ENTORNO - STACK LOCAL / DOCKER DEV
# ===================================================================

# -------------------------------------------------------------------
# Decisiones base del stack local
# -------------------------------------------------------------------

# Frontend en navegador
FRONTEND_PORT=5173

# Backend publicado al host
BACKEND_PORT=9090

# MailHog publicado al host
MAILHOG_UI_PORT=8025
MAILHOG_SMTP_PORT=1025

# MySQL
# Por defecto queda interno al stack y no se publica al host.
# iteracion futura necesitás exponerlo, usar 3307:3306
# en Compose u override, nunca 3306:3306.
MYSQL_HOST_PORT=3307
MYSQL_DATABASE=eventosbd
MYSQL_ROOT_PASSWORD=root

# -------------------------------------------------------------------
# Backend - perfil docker
# -------------------------------------------------------------------

SPRING_PROFILES_ACTIVE=docker
SPRING_DATASOURCE_URL=jdbc:mysql://mysql:3306/eventosbd?createDatabaseIfNotExist=true&useUnicode=true&characterEncoding=utf8&useSSL=false&serverTimezone=UTC&useTimezone=false
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=root

MAIL_HOST=mailhog
MAIL_PORT=1025
MAIL_FROM=no-reply@example.com
MAIL_MOCK_MODE=false
MAIL_FAIL_ON_ERROR=true
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_SMTP_AUTH=false
MAIL_SMTP_STARTTLS_ENABLE=false

APP_CORS_ALLOWED_ORIGINS=http://localhost:5173

JWT_SECRET=aaee89681dd2ffeec808837802a9fdb19b157c71aea36e1886e42c7b2fe0fd7c
JWT_ACCESS_TOKEN_EXPIRATION=900000
JWT_REFRESH_TOKEN_EXPIRATION=604800000

# -------------------------------------------------------------------
# Frontend - navegador / Vite
# -------------------------------------------------------------------

# Aunque el frontend corra en contenedor, esta URL la usa el browser.
# Por eso en dev debe seguir apuntando al host, no a http://backend:9090
VITE_API_BASE_URL=http://localhost:9090
