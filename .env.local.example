# Backend local sin Docker + MailHog local
SPRING_PROFILES_ACTIVE=local

# MySQL local
SPRING_DATASOURCE_URL=jdbc:mysql://localhost:3306/eventosbd?createDatabaseIfNotExist=true&useUnicode=true&characterEncoding=utf8&useSSL=false&serverTimezone=UTC&useTimezone=false
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=root

# MailHog local
MAIL_HOST=127.0.0.1
MAIL_PORT=1025
MAIL_FROM=no-reply@example.com
MAIL_MOCK_MODE=false
MAIL_FAIL_ON_ERROR=true
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_SMTP_AUTH=false
MAIL_SMTP_STARTTLS_ENABLE=false
MAIL_SMTP_CONNECTION_TIMEOUT=5000
MAIL_SMTP_TIMEOUT=5000
MAIL_SMTP_WRITE_TIMEOUT=5000

APP_CORS_ALLOWED_ORIGINS=http://localhost:5173
